--------------------------------------------------
-- AEGIS COMMAND TERMINAL v1.0
--------------------------------------------------

local monitor = peripheral.find("monitor")
local modem = peripheral.find("modem")

local channel = 1
local password = "7KQ9V2MX4R8PZ1T6N3W5H0JY9BLC8FQA"

term.clear()
term.setCursorPos(1,1)

print("--------------")
print("AEGIS TERMINAL")
print("--------------")
print()

write("Enter terminal key: ")

local input = read("*")


if input ~= password then

    print()
    print("ACCESS DENIED")

    sleep(2)

    os.reboot()

end


print()
print("ACCESS GRANTED")

sleep(1)

if not monitor then
    error("No monitor detected")
end


if not modem then
    error("No modem detected")
end


modem.open(channel)

monitor.setTextScale(0.75)

local width,height = monitor.getSize()


local systems = {

    elevator = {
        status = "UNKNOWN"
    },

    power = {
        status = "UNKNOWN"
    },

    fuel = {
        status = "UNKNOWN"
    }

}

local function clearMonitor()

    monitor.clear()
    monitor.setCursorPos(1,1)

end


local function centerText(text, y)

    local x = math.floor((width - #text) / 2) + 1

    if x < 1 then
        x = 1
    end

    monitor.setCursorPos(x,y)
    monitor.write(text)

end



local function drawHeader()

    centerText(
        "AEGIS COMMAND",
        1
    )

end



local function drawColumns()

    local third = math.floor(width / 3)


    -- section names

    local sections = {
        "COMMAND",
        "COMBAT",
        "PROTOCOLS"
    }


    for i,name in ipairs(sections) do

        local x =
            ((i-1) * third)
            +
            math.floor(
                (third-#name)/2
            )
            + 1


        if x < 1 then
            x = 1
        end


        monitor.setCursorPos(x,3)

        monitor.write(name)

    end



    -- vertical lines only if monitor is wide enough

    if width >= 12 then

        for y=4,height do

            monitor.setCursorPos(third,y)
            monitor.write("|")


            monitor.setCursorPos(third*2,y)
            monitor.write("|")

        end

    end


end



local function drawStatus()


    local third =
        math.floor(width/3)


    monitor.setCursorPos(2,5)

    monitor.write(
        "Elevator:"
    )


    monitor.setCursorPos(2,6)

    monitor.write(
        systems.elevator.status
    )



    if width >= 20 then

        monitor.setCursorPos(
            third+2,
            5
        )

        monitor.write(
            "DEFCON:"
        )


        monitor.setCursorPos(
            third+2,
            6
        )

        monitor.write(
            "GREEN"
        )


    end


end



local function updateScreen()

    clearMonitor()

    drawHeader()

    drawColumns()

    drawStatus()

end

local function handlePacket(packet)


    if packet.system then


        if systems[packet.system] then

            systems[packet.system] =
                packet.data

        else

            systems[packet.system] =
            {
                status = "ONLINE"
            }

        end


    end


end

updateScreen()


while true do


    local event,
          side,
          ch,
          reply,
          message =
          os.pullEvent("modem_message")



    if ch == channel then


        handlePacket(message)

        updateScreen()


    end


end
