-- turret_v6.3.lua
-- Clean rewrite for CBC AWACS turret controller
-- Uses resistance-based yaw/pitch control (NOT PID motor model)

local CONFIG = {
  CHANNEL = 1,
  UPDATE_RATE = 0.05,
  TARGET_TIMEOUT = 5,
  YAW_OFFSET = 90,
  FIRE_DELAY = 0.5,

  DEADZONE = 1.0,

  -- axis calibration (FIX THIS ONCE ONLY)
  AXIS_INVERT = {
    YAW = -1,
    PITCH = 1
  }
}

-- peripherals
local modem = assert(peripheral.find("modem"), "No modem found")
local cannon = assert(peripheral.find("cbc_cannon_mount"), "No cannon found")
modem.open(CONFIG.CHANNEL)

-- state
local target = nil
local lastPacket = 0
local lastFire = 0

-- wiring (your setup)
local YAW_DIR, YAW_BRAKE = "bottom", "left"
local PITCH_DIR, PITCH_BRAKE = "top", "right"

-- math helpers
local function clamp(x,a,b)
  return math.max(a, math.min(b, x))
end

local function norm(a)
  a = a % 360
  if a < 0 then a = a + 360 end
  return a
end

local function angleError(a,b)
  local e = (a - b) % 360
  if e > 180 then e = e - 360 end
  return e
end

-- compute target angles
local function calcAngles(t)
  local cx,cy,cz = cannon.getX(), cannon.getY(), cannon.getZ()
  local dx,dy,dz = t.x-cx, t.y-cy, t.z-cz

  local yaw = math.deg(math.atan2(dz, dx)) + CONFIG.YAW_OFFSET
  local horiz = math.sqrt(dx*dx + dz*dz)
  local pitch = math.deg(math.atan2(dy, horiz))

  return yaw, pitch
end

-- resistance mapping (this is your real control model)
local function resistanceFromError(err)
  local a = math.abs(err)

  if a < 1 then
    return 15 -- full lock
  elseif a < 3 then
    return 12
  elseif a < 8 then
    return 9
  elseif a < 15 then
    return 6
  elseif a < 25 then
    return 3
  else
    return 0 -- free rotation when far
  end
end

-- receiver thread
local function receiver()
  while true do
    local _,_,ch,_,msg = os.pullEvent("modem_message")
    if ch == CONFIG.CHANNEL and type(msg) == "table" and msg.type == "PLANE" then
      target = msg
      lastPacket = os.clock()
    end
  end
end

-- control loop
local function control()
  while true do
    local now = os.clock()

    if target and (now - lastPacket < CONFIG.TARGET_TIMEOUT) then

      local dyaw, dpitch = calcAngles(target)

      local cyaw = norm(cannon.getYaw())
      local cpitch = cannon.getPitch()

      -- ERROR SPACE (corrected per axis)
      local yawErr = angleError(dyaw, cyaw) * CONFIG.AXIS_INVERT.YAW
      local pitchErr = (dpitch - cpitch) * CONFIG.AXIS_INVERT.PITCH

      -- =========================
      -- YAW CONTROL (RESISTANCE MODEL)
      -- =========================
      local yawBrake = resistanceFromError(yawErr)
      local yawDir = yawErr > 0

      if math.abs(yawErr) < CONFIG.DEADZONE then
        yawBrake = 15
        yawDir = false
      end

      redstone.setOutput(YAW_DIR, yawDir)
      redstone.setAnalogOutput(YAW_BRAKE, yawBrake)

      -- =========================
      -- PITCH CONTROL (same model)
      -- =========================
      local pitchBrake = resistanceFromError(pitchErr)
      local pitchDir = pitchErr > 0

      if math.abs(pitchErr) < CONFIG.DEADZONE then
        pitchBrake = 15
        pitchDir = false
      end

      redstone.setOutput(PITCH_DIR, pitchDir)
      redstone.setAnalogOutput(PITCH_BRAKE, pitchBrake)

      -- =========================
      -- FIRE CONTROL
      -- =========================
      if math.abs(yawErr) < 1 and math.abs(pitchErr) < 1 then
        if now - lastFire > CONFIG.FIRE_DELAY then
          cannon.fire()
          lastFire = now
        end
      end

      -- debug
      term.setCursorPos(1,1)
      term.clear()

      print("CBC Turret v7 (clean rewrite)")
      print(("YawErr: %.2f  PitchErr: %.2f"):format(yawErr, pitchErr))
      print(("YawBrake: %d  PitchBrake: %d"):format(yawBrake, pitchBrake))

    else
      -- safe state
      redstone.setOutput(YAW_DIR, false)
      redstone.setOutput(PITCH_DIR, false)

      redstone.setAnalogOutput(YAW_BRAKE, 15)
      redstone.setAnalogOutput(PITCH_BRAKE, 15)
    end

    sleep(CONFIG.UPDATE_RATE)
  end
end

parallel.waitForAny(receiver, control)
