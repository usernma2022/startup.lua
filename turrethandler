-- turret_v5.4.lua
-- Inertial tracking controller (fast approach + natural oscillation)

local CONFIG = {
  CHANNEL = 1,
  UPDATE_RATE = 0.05,
  TARGET_TIMEOUT = 5,
  YAW_OFFSET = 90,
  FIRE_DELAY = 0.5,

  DEADZONE = 0.5,

  -- tuning (MAIN CONTROL KNOB)
  YAW_GAIN = 0.35,
  PITCH_GAIN = 0.35,

  AXIS_INVERT = {
    YAW = -1,
    PITCH = 1
  }
}

-- peripherals
local modem = assert(peripheral.find("modem"), "No modem found")
local cannon = assert(peripheral.find("cbc_cannon_mount"), "No cannon found")
modem.open(CONFIG.CHANNEL)

-- state
local target = nil
local lastPacket = 0
local lastFire = 0

-- redstone mapping
local YAW_DIR, YAW_POWER = "bottom", "left"
local PITCH_DIR, PITCH_POWER = "top", "right"

-- utils
local function clamp(x, a, b)
  return math.max(a, math.min(b, x))
end

local function norm(a)
  a = a % 360
  if a < 0 then a = a + 360 end
  return a
end

local function angleError(a, b)
  local e = (a - b) % 360
  if e > 180 then e = e - 360 end
  return e
end

-- target angles
local function calcAngles(t)
  local cx, cy, cz = cannon.getX(), cannon.getY(), cannon.getZ()
  local dx, dy, dz = t.x - cx, t.y - cy, t.z - cz

  local yaw = math.deg(math.atan2(dz, dx)) + CONFIG.YAW_OFFSET
  local horiz = math.sqrt(dx * dx + dz * dz)
  local pitch = math.deg(math.atan2(dy, horiz))

  return yaw, pitch
end

-- receiver
local function receiver()
  while true do
    local _, _, ch, _, msg = os.pullEvent("modem_message")
    if ch == CONFIG.CHANNEL and type(msg) == "table" and msg.type == "PLANE" then
      target = msg
      lastPacket = os.clock()
    end
  end
end

-- control loop
local function control()
  while true do
    local now = os.clock()

    if target and (now - lastPacket < CONFIG.TARGET_TIMEOUT) then

      local dyaw, dpitch = calcAngles(target)

      local cyaw = norm(cannon.getYaw())
      local cpitch = cannon.getPitch()

      -- ERROR SPACE
      local yawErr = angleError(dyaw, cyaw) * CONFIG.AXIS_INVERT.YAW
      local pitchErr = (dpitch - cpitch) * CONFIG.AXIS_INVERT.PITCH

      -- =========================
      -- YAW (INERTIAL OSCILLATION MODEL)
      -- =========================
      local yawPower = clamp(math.abs(yawErr) * CONFIG.YAW_GAIN, 0, 15)
      local yawDir = yawErr > 0

      if math.abs(yawErr) < CONFIG.DEADZONE then
        -- do NOT lock, allow natural overshoot decay
        yawPower = 0
      end

      redstone.setOutput(YAW_DIR, yawDir)
      redstone.setAnalogOutput(YAW_POWER, yawPower)

      -- =========================
      -- PITCH (same model)
      -- =========================
      local pitchPower = clamp(math.abs(pitchErr) * CONFIG.PITCH_GAIN, 0, 15)
      local pitchDir = pitchErr > 0

      if math.abs(pitchErr) < CONFIG.DEADZONE then
        pitchPower = 0
      end

      redstone.setOutput(PITCH_DIR, pitchDir)
      redstone.setAnalogOutput(PITCH_POWER, pitchPower)

      -- =========================
      -- FIRE
      -- =========================
      if math.abs(yawErr) < 1 and math.abs(pitchErr) < 1 then
        if now - lastFire > CONFIG.FIRE_DELAY then
          cannon.fire()
          lastFire = now
        end
      end

      -- debug
      term.setCursorPos(1,1)
      term.clear()

      print("CBC Turret v8 (inertial tracking)")
      print(("YawErr: %.2f  PitchErr: %.2f"):format(yawErr, pitchErr))
      print(("YawPower: %.2f  PitchPower: %.2f"):format(yawPower, pitchPower))

    else
      redstone.setOutput(YAW_DIR, false)
      redstone.setOutput(PITCH_DIR, false)
      redstone.setAnalogOutput(YAW_POWER, 0)
      redstone.setAnalogOutput(PITCH_POWER, 0)
    end

    sleep(CONFIG.UPDATE_RATE)
  end
end

parallel.waitForAny(receiver, control)
