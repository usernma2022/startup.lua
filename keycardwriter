-- AEGIS Security Server v7.0
-- Part 1/2

local MODEM_SIDE = "left"
local CHANNEL = 25

local DATABASE = "cards.db"
local LOGFILE = "access.log"

local OWNER = "Usernam_"

local modem = peripheral.wrap(MODEM_SIDE)
local drive = peripheral.find("drive")
local detector = peripheral.find("playerDetector")

if not modem then
    error("No modem found")
end

if not detector then
    error("No player detector found")
end

modem.open(CHANNEL)


math.randomseed(os.epoch("utc"))

local HEX = "0123456789ABCDEF"


local facilityActive = false



local function randomHex(length)

    local s = ""

    for i = 1,length do

        local n = math.random(#HEX)

        s = s .. HEX:sub(n,n)

    end

    return s

end



local function generateID()

    return randomHex(8).."-"..
           randomHex(4).."-"..
           randomHex(4).."-"..
           randomHex(4).."-"..
           randomHex(12)

end



local function loadDatabase()

    if fs.exists(DATABASE) then

        local f = fs.open(DATABASE,"r")

        local data =
            textutils.unserialize(
                f.readAll()
            )

        f.close()

        return data or {}

    end

    return {}

end



local cards = loadDatabase()



local function saveDatabase()

    local f = fs.open(DATABASE,"w")

    f.write(
        textutils.serialize(cards)
    )

    f.close()

end



local function log(text)

    local f = fs.open(LOGFILE,"a")

    f.writeLine(
        "["..
        os.date("%Y-%m-%d %H:%M:%S")..
        "] "..text
    )

    f.close()

end



local function checkOwner()

    for _,player in pairs(
        detector.getOnlinePlayers()
    ) do

        if player == OWNER then
            return true
        end

    end

    return false

end



local function securityLoop()

    while true do

        local previous = facilityActive

        facilityActive = checkOwner()


        if previous ~= facilityActive then

            if facilityActive then

                log(
                    "FACILITY ONLINE - OWNER PRESENT"
                )

            else

                log(
                    "FACILITY OFFLINE - OWNER LEFT"
                )

            end

        end


        sleep(5)

    end

end



local function writeCard(id,data)

    if not drive then

        print("No floppy drive attached")

        return false

    end


    if not drive.isDiskPresent() then

        print("Insert floppy")

        return false

    end



    local mount =
        drive.getMountPath()



    local function write(name,value)

        local f =
            fs.open(
                fs.combine(mount,name),
                "w"
            )

        f.write(value)

        f.close()

    end



    write(
        "auth.dat",
        id
    )


    write(
        "security.dat",
        textutils.serialize({
            clearance =
                data.security.clearance,
            version = 7
        })
    )


    write(
        "card.dat",
        textutils.serialize({
            owner =
                data.card.owner,

            issued =
                data.card.issued,

            issuer =
                "AEGIS"
        })
    )


    return true

end

-- AEGIS Security Server v7.0
-- Part 2/2


local function createCard()

    term.clear()
    term.setCursorPos(1,1)

    print("CREATE CARD")
    print()


    write("Owner: ")
    local owner = read()


    write("Clearance 1-5: ")
    local clearance = tonumber(read())


    if not clearance or clearance < 1 or clearance > 5 then

        print("Invalid clearance")
        sleep(2)

        return

    end



    local id

    repeat

        id = generateID()

    until not cards[id]



    cards[id] = {

        security = {

            clearance = clearance,
            version = 7

        },


        card = {

            owner = owner,
            issued = os.date("%Y-%m-%d %H:%M:%S"),
            issuer = "AEGIS"

        },


        status = "active"

    }



    saveDatabase()



    print()
    print("Card registered")
    print(id)

    print()
    print("Write floppy? Y/N")


    if read():lower()=="y" then

        if writeCard(id,cards[id]) then

            print("Card written")

        end

    end



    log(
        "CREATED "..id..
        " OWNER "..owner
    )


    sleep(3)

end



local function viewCards()

    term.clear()
    term.setCursorPos(1,1)


    print("CARDS")
    print()


    for id,c in pairs(cards) do

        print(id)

        print(
            c.card.owner..
            " | Level "..
            c.security.clearance..
            " | "..
            c.status
        )

        print()

    end


    read()

end



local function revoke()

    term.clear()
    term.setCursorPos(1,1)


    local list = {}


    print("ACTIVE CARDS")
    print()


    for id,c in pairs(cards) do


        if c.status == "active" then


            table.insert(list,id)


            print(
                #list..
                ") "..
                c.card.owner
            )


            print(id)

            print()


        end


    end



    write("> ")

    local choice =
        tonumber(read())


    local id =
        list[choice]


    if id then


        cards[id].status = "revoked"

        cards[id].security.clearance = 0


        saveDatabase()


        print("Revoked")


        log(
            "REVOKED "..id
        )


    end


    sleep(2)

end



local function restore()


    term.clear()
    term.setCursorPos(1,1)


    write("Card ID: ")

    local id = read()



    if cards[id] then


        cards[id].status = "active"


        saveDatabase()


        print("Restored")


        log(
            "RESTORED "..id
        )


    else

        print("Not found")

    end


    sleep(2)

end



local function status()

    term.clear()
    term.setCursorPos(1,1)


    print("AEGIS STATUS")
    print()


    if facilityActive then

        print("Facility: ONLINE")
        print("Owner detected")

    else

        print("Facility: OFFLINE")
        print("Owner not detected")

    end


    print()

    read()

end



local function network()

    while true do


        local _,_,channel,_,msg =
            os.pullEvent("modem_message")



        if channel == CHANNEL
        and type(msg)=="table"
        and msg.type=="check_card" then



            local card =
                cards[msg.id]



            local reply = {

                type="card_result",

                request=msg.request,

                allowed=false

            }



            if not facilityActive then


                reply.reason =
                    "Facility Offline"


                log(
                    "DENIED OFFLINE "..msg.id
                )



            elseif card
            and card.status=="active"
            and card.security.clearance >= msg.required then



                reply.allowed = true

                reply.owner =
                    card.card.owner

                reply.clearance =
                    card.security.clearance



                log(
                    "ACCESS "..msg.id
                )



            else


                reply.reason =
                    "Denied"


                log(
                    "DENIED "..msg.id
                )


            end



            modem.transmit(
                CHANNEL,
                CHANNEL,
                reply
            )


        end


    end

end



local function menu()

    while true do


        term.clear()
        term.setCursorPos(1,1)


        print("======== AEGIS ========")
        print()


        print("1. View Cards")
        print("2. Create Card")
        print("3. Revoke Card")
        print("4. Restore Card")
        print("5. Facility Status")
        print("6. Exit")


        print()


        local c = read()



        if c=="1" then

            viewCards()


        elseif c=="2" then

            createCard()


        elseif c=="3" then

            revoke()


        elseif c=="4" then

            restore()


        elseif c=="5" then

            status()


        elseif c=="6" then

            error("Shutdown")


        end


    end

end



parallel.waitForAny(

    network,

    menu,

    securityLoop

)
