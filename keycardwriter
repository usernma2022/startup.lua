local DATABASE = "cards.db"

local HEX = "0123456789ABCDEF"

local function randomHex(length)
    local s = ""
    for i = 1, length do
        local n = math.random(#HEX)
        s = s .. HEX:sub(n,n)
    end
    return s
end

math.randomseed(os.epoch("utc"))

local function generateID()
    return randomHex(8).."-"..
           randomHex(4).."-"..
           randomHex(4).."-"..
           randomHex(4).."-"..
           randomHex(12)
end


local cards = {}

if fs.exists(DATABASE) then
    local f = fs.open(DATABASE,"r")
    cards = textutils.unserialize(f.readAll()) or {}
    f.close()
end


local function save()
    local f = fs.open(DATABASE,"w")
    f.write(textutils.serialize(cards))
    f.close()
end


local function clear()
    term.clear()
    term.setCursorPos(1,1)
end


local function pause()
    print("\nPress ENTER")
    read()
end


local function register()

    clear()
    print("REGISTER CARD")
    print()

    write("Owner: ")
    local owner = read()

    write("Clearance (1-5): ")
    local level = tonumber(read())

    if not level or level < 1 or level > 5 then
        print("Invalid clearance")
        pause()
        return
    end

    local id = generateID()

    cards[id] = {
        auth = id,

        security = {
            clearance = level,
            version = 2
        },

        card = {
            owner = owner,
            issued = os.date("%Y-%m-%d %H:%M:%S"),
            issuer = "AWACS Security Division"
        },

        status = "active"
    }

    save()

    print()
    print("CARD CREATED")
    print("ID:")
    print(id)
    print("Clearance:",level)

    pause()
end


local function list()

    clear()
    print("CARDS")
    print()

    local amount = 0

    for id,c in pairs(cards) do
        amount = amount + 1

        print(id)
        print("Owner:",c.card.owner)
        print("Clearance:",c.security.clearance)
        print("Status:",c.status)
        print()
    end

    if amount == 0 then
        print("No cards")
    end

    pause()
end


local function revoke()

    clear()
    print("REVOKE CARD")
    print()

    local valid = {}

    for id,c in pairs(cards) do
        if c.status == "active" then
            table.insert(valid,id)
        end
    end

    if #valid == 0 then
        print("No active cards")
        pause()
        return
    end


    for i,id in ipairs(valid) do
        local c = cards[id]
        print(i..") "..c.card.owner)
        print("   "..id)
        print("   Clearance "..c.security.clearance)
        print()
    end


    write("Select card: ")
    local choice = tonumber(read())

    local id = valid[choice]

    if id then
        cards[id].status = "revoked"
        cards[id].security.clearance = 0

        save()

        print("Card revoked")
    else
        print("Invalid choice")
    end

    pause()
end


local function restore()

    clear()
    print("RESTORE CARD")
    print()

    write("Card ID: ")
    local id = read()

    if cards[id] then
        cards[id].status = "active"
        save()
        print("Restored")
    else
        print("Not found")
    end

    pause()
end


local function search()

    clear()
    print("SEARCH")

    write("Card ID: ")
    local id = read()

    local c = cards[id]

    if c then
        print()
        print("Owner:",c.card.owner)
        print("Clearance:",c.security.clearance)
        print("Status:",c.status)
        print("Issued:",c.card.issued)
    else
        print("Not found")
    end

    pause()
end


while true do

    clear()

    print("AWACS CARD DATABASE")
    print()
    print("1. View cards")
    print("2. Register card")
    print("3. Revoke card")
    print("4. Restore card")
    print("5. Search")
    print("6. Exit")
    print()

    write("> ")
    local c = read()


    if c == "1" then
        list()

    elseif c == "2" then
        register()

    elseif c == "3" then
        revoke()

    elseif c == "4" then
        restore()

    elseif c == "5" then
        search()

    elseif c == "6" then
        break
    end
end
