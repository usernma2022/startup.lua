-- AEGIS Security Server v5.0

local MODEM_SIDE = "left"
local CHANNEL = 25

local DATABASE = "cards.db"
local LOGFILE = "access.log"


local modem = peripheral.wrap(MODEM_SIDE)

if not modem then
    error("No modem found on "..MODEM_SIDE)
end

modem.open(CHANNEL)


math.randomseed(os.epoch("utc"))

local HEX = "0123456789ABCDEF"


local function randomHex(length)

    local s = ""

    for i = 1,length do
        local n = math.random(#HEX)
        s = s .. HEX:sub(n,n)
    end

    return s
end


local function generateID()

    return randomHex(8).."-"..
           randomHex(4).."-"..
           randomHex(4).."-"..
           randomHex(4).."-"..
           randomHex(12)

end


local function loadDatabase()

    if not fs.exists(DATABASE) then
        return {}
    end

    local f = fs.open(DATABASE,"r")
    local data = textutils.unserialize(f.readAll())
    f.close()

    return data or {}

end


local cards = loadDatabase()


local function saveDatabase()

    local f = fs.open(DATABASE,"w")
    f.write(textutils.serialize(cards))
    f.close()

end


local function log(text)

    local f = fs.open(LOGFILE,"a")

    f.writeLine(
        "["..
        os.date("%Y-%m-%d %H:%M:%S")..
        "] "..text
    )

    f.close()

end



local function createCard(msg)

    local id

    repeat
        id = generateID()
    until not cards[id]


    cards[id] = {

        security = {
            clearance = msg.clearance,
            version = 5
        },

        card = {
            owner = msg.owner,
            issued = os.date("%Y-%m-%d %H:%M:%S"),
            issuer = "AEGIS"
        },

        status = "active"

    }


    saveDatabase()


    modem.transmit(
        CHANNEL,
        CHANNEL,
        {
            type="card_created",
            request=msg.request,
            id=id,
            owner=msg.owner,
            clearance=msg.clearance
        }
    )


    log(
        "CARD CREATED "..id..
        " OWNER "..msg.owner
    )

end



local function checkCard(msg)

    local result = {

        type="card_result",
        request=msg.request,
        allowed=false

    }


    local card = cards[msg.id]


    if not card then

        result.reason="Unknown card"


    elseif card.status ~= "active" then

        result.reason="Card revoked"


    elseif card.security.clearance < msg.required then

        result.reason="Insufficient clearance"


    else

        result.allowed=true
        result.owner=card.card.owner
        result.clearance=card.security.clearance

    end



    if result.allowed then

        log(
            "ACCESS GRANTED "..msg.id..
            " "..result.owner
        )

    else

        log(
            "ACCESS DENIED "..msg.id..
            " "..result.reason
        )

    end


    modem.transmit(
        CHANNEL,
        CHANNEL,
        result
    )

end



local function networkLoop()

    while true do

        local _,_,channel,_,msg =
            os.pullEvent("modem_message")


        if channel == CHANNEL
        and type(msg)=="table" then


            if msg.type=="create_card" then

                createCard(msg)


            elseif msg.type=="check_card" then

                checkCard(msg)

            end

        end

    end

end



local function showCards()

    term.clear()
    term.setCursorPos(1,1)

    print("AEGIS CARD DATABASE")
    print()


    for id,c in pairs(cards) do

        print(id)

        print(
            c.card.owner..
            " | Clearance: "..
            c.security.clearance..
            " | "..c.status
        )

        print()

    end


    print("Press ENTER")

    read()

end



local function revokeCard()

    term.clear()
    term.setCursorPos(1,1)

    print("ACTIVE CARDS")
    print()


    local list={}


    for id,c in pairs(cards) do

        if c.status=="active" then

            table.insert(list,id)

            print(
                #list..
                ") "..
                c.card.owner
            )

            print(id)
            print()

        end

    end


    print("Select:")

    local choice = tonumber(read())


    local id = list[choice]


    if id then

        cards[id].status="revoked"
        cards[id].security.clearance=0

        saveDatabase()

        print("Card revoked")

    end


    sleep(2)

end



local function restoreCard()

    term.clear()
    term.setCursorPos(1,1)


    write("Card ID: ")

    local id = read()


    if cards[id] then

        cards[id].status="active"

        saveDatabase()

        print("Restored")

    else

        print("Not found")

    end


    sleep(2)

end



local function changeClearance()

    term.clear()
    term.setCursorPos(1,1)


    write("Card ID: ")

    local id = read()


    if not cards[id] then

        print("Not found")
        sleep(2)
        return

    end


    write("New clearance: ")

    local level = tonumber(read())


    if level and level >=0 and level<=5 then

        cards[id].security.clearance=level

        if level==0 then
            cards[id].status="revoked"
        end

        saveDatabase()

        print("Updated")

    end


    sleep(2)

end



local function adminLoop()

    while true do

        term.clear()
        term.setCursorPos(1,1)

        print("====================")
        print(" AEGIS SECURITY")
        print("====================")
        print()
        print("1. View cards")
        print("2. Revoke card")
        print("3. Restore card")
        print("4. Change clearance")
        print("5. Exit")
        print()


        local choice = read()


        if choice=="1" then

            showCards()


        elseif choice=="2" then

            revokeCard()


        elseif choice=="3" then

            restoreCard()


        elseif choice=="4" then

            changeClearance()


        elseif choice=="5" then

            error("Server stopped")

        end

    end

end



parallel.waitForAny(
    networkLoop,
    adminLoop
)
