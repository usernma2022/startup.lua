-- AEGIS Keycard Reader v5.0

local MODEM_SIDE = "left"
local CHANNEL = 25

local REQUIRED_CLEARANCE = 3

local OUTPUT_SIDE = "back"
local OPEN_TIME = 3


local drive = peripheral.find("drive")
local modem = peripheral.wrap(MODEM_SIDE)


if not drive then
    error("No floppy drive found")
end

if not modem then
    error("No modem found on "..MODEM_SIDE)
end


modem.open(CHANNEL)



local function readFile(path)

    if not fs.exists(path) then
        return nil
    end

    local f = fs.open(path,"r")
    local data = f.readAll()
    f.close()

    return data

end



while true do

    term.clear()
    term.setCursorPos(1,1)

    print("====================")
    print("  AEGIS ACCESS")
    print("====================")
    print()

    print("Insert keycard...")


    while not drive.isDiskPresent() do
        sleep(0.1)
    end


    local mount = drive.getMountPath()


    local cardID = readFile(
        fs.combine(mount,"auth.dat")
    )


    if not cardID then

        print()
        print("Invalid card")
        drive.ejectDisk()
        sleep(2)

    else


        local request = os.getComputerID()


        modem.transmit(
            CHANNEL,
            CHANNEL,
            {
                type = "check_card",
                request = request,
                id = cardID,
                required = REQUIRED_CLEARANCE
            }
        )


        local result


        while true do

            local _,_,channel,_,msg =
                os.pullEvent("modem_message")


            if channel == CHANNEL
            and type(msg) == "table"
            and msg.type == "card_result"
            and msg.request == request then

                result = msg
                break

            end

        end



        term.clear()
        term.setCursorPos(1,1)


        if result.allowed then

            print("ACCESS GRANTED")
            print()

            print("User:")
            print(result.owner)

            print()

            print("Clearance:")
            print(result.clearance)


            redstone.setOutput(
                OUTPUT_SIDE,
                true
            )


            sleep(OPEN_TIME)


            redstone.setOutput(
                OUTPUT_SIDE,
                false
            )


        else

            print("ACCESS DENIED")
            print()

            print(result.reason)

        end


        drive.ejectDisk()

        sleep(2)

    end

end
