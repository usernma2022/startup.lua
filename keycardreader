-- AEGIS Keycard Reader v6.0

local MODEM_SIDE = "left"
local CHANNEL = 25

local REQUIRED_CLEARANCE = 3

local DOOR_OUTPUT = "back"
local OPEN_TIME = 3


local drive = peripheral.find("drive")
local modem = peripheral.wrap(MODEM_SIDE)


if not drive then
    error("No floppy drive found")
end

if not modem then
    error("No modem found")
end


modem.open(CHANNEL)



local function readFile(path)

    if not fs.exists(path) then
        return nil
    end

    local f = fs.open(path,"r")
    local data = f.readAll()
    f.close()

    return data

end



local function eject()

    if drive.isDiskPresent() then
        drive.ejectDisk()
    end

end



while true do

    term.clear()
    term.setCursorPos(1,1)

    print("====================")
    print("   AEGIS ACCESS")
    print("====================")
    print()
    print("Insert keycard")


    while not drive.isDiskPresent() do
        sleep(0.1)
    end



    local mount = drive.getMountPath()


    local cardID = readFile(
        fs.combine(mount,"auth.dat")
    )


    if not cardID then

        print()
        print("INVALID CARD")

        eject()

        sleep(2)

        os.reboot()

    end



    local request = os.getComputerID()


    modem.transmit(
        CHANNEL,
        CHANNEL,
        {
            type="check_card",
            request=request,
            id=cardID,
            required=REQUIRED_CLEARANCE
        }
    )



    local result


    while true do

        local _,_,channel,_,msg =
            os.pullEvent("modem_message")


        if channel==CHANNEL
        and type(msg)=="table"
        and msg.type=="card_result"
        and msg.request==request then

            result=msg
            break

        end

    end



    term.clear()
    term.setCursorPos(1,1)



    if result.allowed then

        print("ACCESS GRANTED")
        print()
        print(result.owner)
        print("Clearance "..result.clearance)


        -- Pulse door

        redstone.setOutput(
            DOOR_OUTPUT,
            true
        )


        eject()


        sleep(OPEN_TIME)


        redstone.setOutput(
            DOOR_OUTPUT,
            false
        )


    else

        print("ACCESS DENIED")
        print()
        print(result.reason)


        eject()

    end



    sleep(1)

    os.reboot()

end
