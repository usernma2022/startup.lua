local PASSWORD = "Username"

local oldPullEvent = os.pullEventRaw

os.pullEventRaw = function(filter)

    local event = {oldPullEvent(filter)}

    if event[1] == "terminate" then

        term.clear()
        term.setCursorPos(1,1)

        term.write("Password: ")

        local input = read("*")

        if input ~= PASSWORD then

            print("ACCESS DENIED")

            return os.pullEventRaw(filter)

        end

    end

    return table.unpack(event)

end

local detector = peripheral.find("playerDetector")
local modem = peripheral.find("modem")

if not detector then error("Player Detector missing") end
if not modem then error("Modem missing") end


local CHANNEL = 48291
local alarm = false
local HOST = "NORTH_RADAR"
local ORIGIN_X = 0
local ORIGIN_Z = 0
local sweepAngle = 0
local RADAR_RANGE = 192
local UPDATE_TIME = 1


modem.open(CHANNEL)



local function distance(x,z)

    return math.floor(
        math.sqrt(x*x+z*z)
    )

end



local function sendPacket(packet)

    modem.transmit(
        CHANNEL,
        CHANNEL,
        packet
    )

end



local function sendStatus()

    sendPacket({

        type="RADAR_STATUS",

        host=HOST,

        x=ORIGIN_X,

        z=ORIGIN_Z,

        range=RADAR_RANGE,

        sweep=sweepAngle

    })

end

local function sendContacts()

    local players = detector.getPlayersInRange(
        RADAR_RANGE
    )

    local contacts = {}


    for _,name in ipairs(players) do

        local pos = detector.getPlayerPos(name)

        if pos then

            table.insert(
                contacts,
                {
                    name = name,

                    x = pos.x,

                    z = pos.z,

                    source = HOST,

                    distance = distance(
                        pos.x-ORIGIN_X,
                        pos.z-ORIGIN_Z
                    )

                }
            )

        end

    end


    sendPacket({

        type="CONTACTS",

        host=HOST,

        contacts=contacts

    })

end

local function modemLoop()

    while true do

        local _,side,channel,reply,message =
            os.pullEvent("modem_message")


        if channel == CHANNEL
        and type(message)=="table" then

            if message.type=="ACK" then

                alarm=false

                redstone.setOutput(
                    "right",
                    false
                )

            end

        end

    end

end

parallel.waitForAny(

    modemLoop,

    function()

        while true do

            sweepAngle = (sweepAngle + 8) % 360

            sendStatus()

            sendContacts()

            sleep(UPDATE_TIME)

        end

    end

)
