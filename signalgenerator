-- ComputerCraft Modem Test Signal Generator

local modem = peripheral.find("modem")

if not modem then
    error("No modem found")
end


-- Change this to the channel you want to test
local CHANNEL = 48291


local messages = {
    {
        type = "TEST",
        system = "RADAR",
        contacts = 3
    },

    {
        type = "STATUS",
        system = "AWACS",
        state = "ONLINE"
    },

    {
        type = "ALERT",
        level = "RED"
    },

    {
        type = "PING",
        source = "TEST_DEVICE"
    }
}


print("Sending test traffic on channel " .. CHANNEL)


local id = 0


while true do

    id = id + 1


    local packet =
    {
        id = id,
        sender = "TEST_TRANSMITTER",
        time = os.date("%H:%M:%S"),
        data = messages[
            math.random(
                1,
                #messages
            )
        ]
    }


    modem.transmit(
        CHANNEL,
        CHANNEL,
        packet
    )


    print(
        "Sent packet #"
        .. id
    )


    sleep(2)

end
