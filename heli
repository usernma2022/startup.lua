local ship = peripheral.wrap("back")

while true do
    local q = ship.getQuaternion()
    local vel = ship.getVelocity()
    local omega = ship.getOmega()

    term.clear()
    term.setCursorPos(1,1)

    print("Rotation")
    print("a:", q.a)
    print("x:", q.v.x)
    print("y:", q.v.y)
    print("z:", q.v.z)

    print("")
    print("Velocity")
    print(vel.x, vel.y, vel.z)

    print("")
    print("Omega")
    print(omega.x, omega.y, omega.z)

    sleep(0.1)
end
