local targetRoll = 0
local targetPitch = 0

while true do

    local q = ship.getQuaternion()

    -- CHANGE THESE BASED ON YOUR TESTS
    local roll = q.v.x
    local pitch = q.v.y

    local rollError = roll - targetRoll
    local pitchError = pitch - targetPitch

    term.clear()
    term.setCursorPos(1,1)

    print("ATTITUDE MONITOR")
    print("")

    print("Roll:")
    print(roll)

    print("Roll Error:")
    print(rollError)

    print("")

    print("Pitch:")
    print(pitch)

    print("Pitch Error:")
    print(pitchError)

    sleep(0.1)

end
