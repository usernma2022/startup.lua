while true do
    local q = ship.getQuaternion()
    local vel = ship.getVelocity()
    local ang = ship.getAngularVelocity()

    term.clear()
    term.setCursorPos(1,1)

    print("Quaternion")
    print("a:", q.a)
    print("x:", q.v.x)
    print("y:", q.v.y)
    print("z:", q.v.z)

    print("")
    print("Velocity")
    print(vel.x, vel.y, vel.z)

    print("")
    print("Angular Velocity")
    print(ang.x, ang.y, ang.z)

    sleep(0.1)
end
