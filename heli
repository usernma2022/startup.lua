local side = "back"

print("Flap controller")
print("Enter redstone level (0-15)")
print("Type exit to quit")

while true do
    write("> ")
    local input = read()

    if input == "exit" then
        break
    end

    local power = tonumber(input)

    if power and power >= 0 and power <= 15 then
        redstone.setAnalogOutput(side, power)
        print("Output set to:", power)
    else
        print("Invalid value. Use 0-15")
    end
end

redstone.setAnalogOutput(side, 0)
