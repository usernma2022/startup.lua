local gain = 50

while true do
    local q = ship.getQuaternion()

    local roll = q.v.x

    -- calculate correction
    local correction = math.floor(roll * gain)

    -- limit
    if correction > 15 then
        correction = 15
    elseif correction < -15 then
        correction = -15
    end

    -- differential flap control
    redstone.setAnalogOutput("left", 8 + correction)
    redstone.setAnalogOutput("right", 8 - correction)

    sleep(0.05)
end
