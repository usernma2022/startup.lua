local CHANNEL = 1

local modem = peripheral.find("modem")
local cannon = peripheral.find("cbc_cannon_mount")

assert(modem)
assert(cannon)

modem.open(CHANNEL)

local target

local PITCH_DIR = "top"

local lastDir = nil

local function calcPitch()

    if not target then
        return nil
    end

    local dx = target.x - cannon.getX()
    local dy = target.y - cannon.getY()
    local dz = target.z - cannon.getZ()

    local horiz = math.sqrt(dx*dx + dz*dz)

    return math.deg(math.atan2(dy, horiz))

end

parallel.waitForAny(

function()

    while true do

        local _,_,ch,_,msg = os.pullEvent("modem_message")

        if ch == CHANNEL and type(msg) == "table" and msg.type == "PLANE" then
            target = msg
        end

    end

end,

function()

    while true do

        term.clear()
        term.setCursorPos(1,1)

        if target then

            local desired = calcPitch()
            local actual = cannon.getPitch()

            local err = desired - actual

            local dir = err > 0

            -- ONLY send a redstone update if the direction changed
            if dir ~= lastDir then
                redstone.setOutput(PITCH_DIR, dir)
                lastDir = dir
            end

            print(("Desired: %.2f"):format(desired))
            print(("Actual : %.2f"):format(actual))
            print(("Error  : %.2f"):format(err))
            print()
            print("Direction:")
            print(dir and "UP" or "DOWN")
            print()
            print("Updates sent:")
            print(lastDir == dir and "No new update" or "Changed")

        else

            print("Waiting for target...")

        end

        sleep(0.05)

    end

end
)
