local monitor = peripheral.find("monitor")
local detector = peripheral.find("playerDetector")
local modem = peripheral.find("modem")

if not monitor then error("Monitor missing") end
if not detector then error("Player Detector missing") end

monitor.setTextScale(0.5)

local w,h = monitor.getSize()
local buffer = window.create(monitor,1,1,w,h)

local NETWORK = true
local CHANNEL = 48291
local HQ_PRIORITY = true
local HOST = "MAIN_HQ"

if modem and NETWORK then
    modem.open(CHANNEL)
end

local RADAR_RANGE = 192

local zoomLevels = {
    64,
    96,
    192,
    256,
    384,
    512,
    1024
}

local zoom = 192

local origin = {
    x = 0,
    z = 0
}

local sweepAngle = 0
local alarm = false

local contacts = {}
local remoteContacts = {}
local remoteRadars = {}
local previousContacts = {}

local authorized = {}

local function drawText(t,x,y,text,color)

    if x < 1 or x > w or y < 1 or y > h then
        return
    end

    t.setCursorPos(math.floor(x),math.floor(y))
    t.setTextColor(color)
    t.write(text)

end

local function distance(x,z)

    return math.floor(
        math.sqrt(x*x+z*z)
    )

end

local function worldToRadar(x,z)

    return math.floor(w/2+x*(w/2)/zoom),
           math.floor(h/2-z*(h/2)/zoom)

end

local function radarRadius(range)

    return range*(w/2)/zoom

end

local function sendPacket(packet)

    if modem and NETWORK then

        modem.transmit(
            CHANNEL,
            CHANNEL,
            packet
        )

    end

end

if not fs.exists("authorized.cfg") then

    local file = fs.open("authorized.cfg","w")
    file.close()

end


local function loadAuthorization()

    local file = fs.open("authorized.cfg","r")

    while true do

        local line = file.readLine()

        if not line then
            break
        end

        if line ~= "" then
            authorized[line] = true
        end

    end

    file.close()

end


local function saveAuthorization()

    local file = fs.open("authorized.cfg","w")

    for name,_ in pairs(authorized) do
        file.writeLine(name)
    end

    file.close()

end


loadAuthorization()


local function isAuthorized(name)

    return authorized[name] == true

end


local function authTerminal()

    term.clear()
    term.setCursorPos(1,1)

    print("=== AUTHORIZATION ===")
    print("")
    print("Enter player name:")

    term.write("> ")

    local name = read()


    if name and name ~= "" then

        if not authorized[name] then

            authorized[name] = true
            saveAuthorization()

        end

    end

end


local function acknowledge()

    alarm = false

    redstone.setOutput(
        "right",
        false
    )

end

local function updateContacts()

    local players = detector.getPlayersInRange(
        RADAR_RANGE
    )

    local newContacts = {}

    for _,name in ipairs(players) do

        local pos = detector.getPlayerPos(name)

        if pos then

            local x = pos.x - origin.x
            local z = pos.z - origin.z

            local contact = {
                name = name,
                x = x,
                z = z,
                distance = distance(x,z),
                authorized = isAuthorized(name)
            }

            table.insert(
                newContacts,
                contact
            )


            if not contact.authorized
            and not previousContacts[name] then

                alarm = true

                redstone.setOutput(
                    "right",
                    true
                )

            end

        end

    end


    previousContacts = {}

    for _,contact in ipairs(newContacts) do

        previousContacts[contact.name] = true

    end


    contacts = newContacts


    for _,list in pairs(remoteContacts) do

        for _,contact in ipairs(list) do

            local exists = false

            for _,localContact in ipairs(contacts) do

                if localContact.name == contact.name then

                    exists = true
                    break

                end

            end


            if not exists then

                table.insert(
                    contacts,
                    contact
                )

            end

        end

    end


    sendPacket({

        type = "RADAR_STATUS",

        host = HOST,

        x = origin.x,

        z = origin.z,

        range = RADAR_RANGE

    })


    sendPacket({

        type = "CONTACTS",

        host = HOST,

        contacts = contacts

    })

end


local function updateRemoteRadar(message)

    remoteRadars[message.host] = {

        x = message.x,

        z = message.z,

        range = message.range,

        sweep = message.sweep or 0,

        time = os.time()

    }

end


local function updateRemoteContacts(message)

    remoteContacts[message.host] = message.contacts

end

local function drawBackground()

    buffer.setBackgroundColor(colors.black)
    buffer.clear()


    for y=2,h-2 do

        for x=1,w do

            if x%5==0 and y%3==0 then

                drawText(
                    buffer,
                    x,
                    y,
                    ".",
                    colors.gray
                )

            end

        end

    end


    local r = radarRadius(RADAR_RANGE)


    for a=0,360,3 do

        local rad = math.rad(a)

        drawText(
            buffer,
            w/2+math.cos(rad)*r,
            h/2+math.sin(rad)*r*(h/w),
            ".",
            colors.lightBlue
        )

    end


    for _,radar in pairs(remoteRadars) do

        local x,z =
            radar.x-origin.x,
            radar.z-origin.z


        local sx,sy = worldToRadar(x,z)

        local radius = radarRadius(
            radar.range
        )


        for a=0,360,4 do

            local angle = math.rad(a)

            drawText(
                buffer,
                sx+math.cos(angle)*radius,
                sy+math.sin(angle)*radius*(h/w),
                ".",
                colors.lightBlue
            )

        end

    end


    drawText(
        buffer,
        w/2,
        1,
        "N",
        colors.white
    )

    drawText(
        buffer,
        w/2,
        h,
        "S",
        colors.white
    )

    drawText(
        buffer,
        1,
        h/2,
        "W",
        colors.white
    )

    drawText(
        buffer,
        w,
        h/2,
        "E",
        colors.white
    )

end

local function drawRemoteSweep()

    for _,radar in pairs(remoteRadars) do

        local x,z =
            radar.x-origin.x,
            radar.z-origin.z


        local sx,sy =
            worldToRadar(x,z)


        local r =
            radarRadius(radar.range)


        for offset=-15,15,2 do

            local angle =
                math.rad(
                    radar.sweep + offset
                )


            for i=1,r do

                local ratio=i/r


                drawText(
                    buffer,
                    sx+math.cos(angle)*r*ratio,
                    sy+math.sin(angle)*r*(h/w)*ratio,
                    ".",
                    colors.green
                )

            end

        end

    end

end

local function drawSweep()

    local r = radarRadius(
        RADAR_RANGE
    )


    for offset=-15,15,2 do

        local angle = math.rad(
            sweepAngle+offset
        )


        for i=1,r do

            local ratio=i/r

            drawText(
                buffer,
                w/2+math.cos(angle)*r*ratio,
                h/2+math.sin(angle)*r*(h/w)*ratio,
                ".",
                colors.green
            )

        end

    end

end



local function labelPosition(x,y,name)

    local lx=x+2
    local ly=y


    if lx+#name>w then

        lx=x-#name-2

    end


    if ly<2 then

        ly=2

    elseif ly>h-3 then

        ly=h-3

    end


    return lx,ly

end



local function drawContacts()

    local occupied={}


    for _,contact in ipairs(contacts) do


        local sx,sy = worldToRadar(
            contact.x,
            contact.z
        )


        if sx>=1 and sx<=w
        and sy>=2 and sy<=h-3 then


            local key=sx..":"..sy


            while occupied[key] do

                sy=sy+2

                key=sx..":"..sy

            end


            occupied[key]=true


            local colour

            if contact.authorized then

                colour=colors.green

            else

                colour=colors.yellow

            end


            drawText(
                buffer,
                sx,
                sy,
                "+",
                colour
            )


            local lx,ly =
                labelPosition(
                    sx,
                    sy,
                    contact.name
                )


            drawText(
                buffer,
                lx,
                ly,
                contact.name,
                colors.white
            )


            drawText(
                buffer,
                lx,
                ly+1,
                contact.distance.."m",
                colors.lightGray
            )

        end

    end

end



local function drawUI()

    drawText(
        buffer,
        2,
        h,
        "[-]",
        colors.white
    )


    drawText(
        buffer,
        6,
        h,
        zoom.."m",
        colors.white
    )


    drawText(
        buffer,
        14,
        h,
        "[+]",
        colors.white
    )


    drawText(
        buffer,
        w-12,
        h,
        "[AUTH]",
        colors.white
    )


    drawText(
        buffer,
        w-5,
        h,
        "[ACK]",
        alarm and colors.red or colors.gray
    )

end



local function render()

    drawBackground()
    drawRemoteSweep()
    drawSweep()
    drawContacts()
    drawUI()
    buffer.redraw()

end

local function changeZoom(amount)

    for i,value in ipairs(zoomLevels) do

        if value == zoom then

            local index = i + amount

            if index < 1 then
                index = 1
            end

            if index > #zoomLevels then
                index = #zoomLevels
            end

            zoom = zoomLevels[index]

            return

        end

    end

end



local function inputLoop()

    while true do

        local _,_,x,y = os.pullEvent(
            "monitor_touch"
        )


        if y == h then


            if x >= 2 and x <= 4 then

                changeZoom(-1)


            elseif x >= 14 and x <= 16 then

                changeZoom(1)


            elseif x >= w-12 and x < w-6 then

                authTerminal()


            elseif x >= w-5 then

                acknowledge()

            end

        end

    end

end



local function modemLoop()

    if not modem or not NETWORK then

        while true do
            sleep(100)
        end

    end


    while true do

        local _,side,channel,reply,message =
            os.pullEvent(
                "modem_message"
            )


        if channel == CHANNEL
        and type(message) == "table" then


            if message.type == "RADAR_STATUS" then

                if message.host ~= HOST then

                    updateRemoteRadar(message)

                end


            elseif message.type == "CONTACTS" then

                if message.host ~= HOST then

                    updateRemoteContacts(message)

                end

            end

        end

    end

end



local function radarLoop()

    while true do

        updateContacts()

        render()


        sweepAngle =
            (sweepAngle+8)%360


        sleep(0.15)

    end

end



parallel.waitForAny(

    inputLoop,

    modemLoop,

    radarLoop

)
