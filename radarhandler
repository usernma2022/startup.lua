local function warn(msg)
    print("[AWACS WARNING] " .. msg)
end

-- peripherals
local chat = peripheral.find("chatBox")
local detector = peripheral.find("player_detector") or peripheral.find("playerDetector")
local modem = peripheral.find("modem")
local monitor = peripheral.find("monitor") or term

if not detector then warn("Player Detector missing - radar disabled") end
if not modem then warn("Modem missing - network disabled") else modem.open(1) end
if not chat then warn("ChatBox missing - alerts disabled") end

local w, h = monitor.getSize()

local cfg = {
    x = 0, y = 0, z = 0,
    range = 1000,
    update = 1,
    host = "Usernam_",
    cooldown = 10,
    chatBroadcast = true
}

local memory = {}
local lastSeen = {}
local alerted = {}

local lastSend = 0
local sendRate = 0.5
local lastAlert = 0

local function classify(v)
    local s = v.speed or 0
    local y = v.y or 0

    local highAltitude = y >= 80
    local fast = s >= 25

    if highAltitude and fast then
        return "PLANE"
    end

    if highAltitude then
        return "AIRBORNE"
    end

    if s >= 6 then
        return "FAST"
    end

    if s < 0.4 then
        return "STATIC"
    end

    return "PLAYER"
end

local function isIncoming(v)
    local o = memory[v.id]
    if not o then return false end

    local vx = o.x - o.px
    local vz = o.z - o.pz

    local dx = cfg.x - o.x
    local dz = cfg.z - o.z

    local vlen = math.sqrt(vx*vx + vz*vz)
    local dlen = math.sqrt(dx*dx + dz*dz)

    if vlen == 0 or dlen == 0 then return false end

    vx, vz = vx / vlen, vz / vlen
    dx, dz = dx / dlen, dz / dlen

    return (vx * dx + vz * dz) > 0.2
end

local function scan()
    if not detector then return end

    for _, name in ipairs(detector.getOnlinePlayers()) do
        local p = detector.getPlayer(name)

        if p then
            local dx = p.x - cfg.x
            local dz = p.z - cfg.z

            if dx*dx + dz*dz <= cfg.range*cfg.range then

                local old = memory[name]

                memory[name] = {
                    id = name,
                    x = p.x,
                    y = p.y,
                    z = p.z,

                    px = old and old.x or p.x,
                    py = old and old.y or p.y,
                    pz = old and old.z or p.z,

                    speed = 0
                }

                local dx2 = memory[name].x - memory[name].px
                local dy2 = memory[name].y - memory[name].py
                local dz2 = memory[name].z - memory[name].pz

                memory[name].speed =
                    math.sqrt(dx2*dx2 + dy2*dy2 + dz2*dz2) / cfg.update

                lastSeen[name] = os.clock()
            end
        end
    end
end

local function cleanup()
    for n, t in pairs(lastSeen) do
        if os.clock() - t > 3 then
            memory[n] = nil
            lastSeen[n] = nil
            alerted[n] = nil
        end
    end
end

local function alert(name, v)
    if not chat or not cfg.chatBroadcast then return end

    local now = os.clock()
    if now - lastAlert < cfg.cooldown then return end
    lastAlert = now

    local tag = (v.speed or 0) >= 25 and "AIR THREAT" or "CONTACT"

    chat.sendMessage(
        "[AWACS] " .. tag .. " DETECTED: " .. name
    )
end

local function grid()
    local cx, cy = math.floor(w/2), math.floor(h/2)

    for x = 1, w do
        monitor.setCursorPos(x, cy)
        monitor.write("-")
    end

    for y = 2, h do
        monitor.setCursorPos(cx, y)
        monitor.write("|")
    end
end

local function toScreen(x, z)
    local cx, cy = math.floor(w/2), math.floor(h/2)
    return cx + (x / cfg.range) * (w/2),
           cy + (z / cfg.range) * (h/2)
end

local function sendPacket(contacts, defcon, playerCount)

    if not modem then return end
    if os.clock() - lastSend < sendRate then return end
    lastSend = os.clock()

    local packet = {
        system = "radar",
        type = "update",
        id = "radar_main",
        timestamp = os.epoch("utc"),

        data = {
            defcon = defcon,
            range = cfg.range,

            position = {
                x = cfg.x,
                y = cfg.y,
                z = cfg.z
            },

            stats = {
                players = playerCount,
                contacts = #contacts
            },

            contacts = contacts
        }
    }

    modem.transmit(1, 1, textutils.serialize(packet))
end

while true do

    scan()
    cleanup()

    local contacts = {}
    local playerCount = 0

    for n, p in pairs(memory) do
        p.type = classify(p)
        table.insert(contacts, p)

        if n ~= cfg.host then
            playerCount = playerCount + 1
        end
    end

    -- DEFCON LOGIC
    local defcon
    local defconColor

    if playerCount == 0 then
        defcon = "GREEN"
        defconColor = colors.green
    elseif playerCount < 5 then
        defcon = "YELLOW"
        defconColor = colors.yellow
    else
        defcon = "RED"
        defconColor = colors.red
    end

    sendPacket(contacts, defcon, playerCount)

    ---------------------------------------------------
    -- DISPLAY
    ---------------------------------------------------

    monitor.clear()
    monitor.setCursorPos(1,1)

    monitor.setTextColor(colors.white)
    monitor.write("AWACS | DEFCON: ")

    monitor.setTextColor(defconColor)
    monitor.write(defcon)

    monitor.setTextColor(colors.white)
    monitor.write(" | P:" .. playerCount)

    grid()

    for _, v in pairs(memory) do
        local x, z = v.x - cfg.x, v.z - cfg.z
        local sx, sy = toScreen(x, z)

        if sx > 0 and sx < w and sy > 1 and sy < h then
            monitor.setCursorPos(sx, sy)

            if v.type == "PLANE" then
                monitor.setTextColor(colors.red)
                monitor.write("A")
            else
                monitor.setTextColor(colors.lightBlue)
                monitor.write("o")
            end
        end

        if v.id ~= cfg.host and isIncoming(v) and (v.speed or 0) > 6 then
            if not alerted[v.id] then
                alert(v.id, v)
                alerted[v.id] = true
            end
        end
    end

    sleep(cfg.update)
end
