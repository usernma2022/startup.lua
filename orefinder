local scanner = peripheral.find("geoScanner")

if not scanner then
    print("No Geo Scanner found.")
    return
end

local oreOptions = {
    {
        name = "Diamond",
        ores = {
            "minecraft:diamond_ore",
            "minecraft:deepslate_diamond_ore"
        }
    },
    {
        name = "Gold",
        ores = {
            "minecraft:gold_ore",
            "minecraft:deepslate_gold_ore"
        }
    },
    {
        name = "Iron",
        ores = {
            "minecraft:iron_ore",
            "minecraft:deepslate_iron_ore"
        }
    }
}

print("=== ORE FINDER ===")
print("")
print("1. Diamond")
print("2. Gold")
print("3. Iron")
print("")

write("Choose ore: ")
local choice = tonumber(read())

if not choice or not oreOptions[choice] then
    print("Invalid choice.")
    return
end

local selected = oreOptions[choice]

while true do

    local results = scanner.scan(16)

    local closest = nil
    local closestDistance = math.huge

    for _, block in ipairs(results) do

        for _, oreName in ipairs(selected.ores) do

            if block.name == oreName then

                local distance = math.sqrt(
                    block.x^2 +
                    block.y^2 +
                    block.z^2
                )

                if distance < closestDistance then
                    closestDistance = distance
                    closest = block
                end

                break
            end

        end

    end

    term.clear()
    term.setCursorPos(1,1)

    print("Tracking: "..selected.name)
    print("")

    if closest then

        print("Closest Ore Found!")
        print("")

        if closest.x > 0 then
            print(closest.x.." blocks East")
        elseif closest.x < 0 then
            print(math.abs(closest.x).." blocks West")
        else
            print("Same East/West position")
        end

        if closest.y > 0 then
            print(closest.y.." blocks Up")
        elseif closest.y < 0 then
            print(math.abs(closest.y).." blocks Down")
        else
            print("Same Height")
        end

        if closest.z > 0 then
            print(closest.z.." blocks South")
        elseif closest.z < 0 then
            print(math.abs(closest.z).." blocks North")
        else
            print("Same North/South position")
        end

        print("")
        print(string.format("Distance: %.1f blocks", closestDistance))

    else

        print("No "..selected.name.." ore found.")

    end

    sleep(0.5)

end
