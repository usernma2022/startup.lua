local scanner = peripheral.find("geoScanner")

if not scanner then
    print("No Geo Scanner found.")
    return
end


local ores = {
    Diamond = {
        ["minecraft:diamond_ore"] = true,
        ["minecraft:deepslate_diamond_ore"] = true
    },

    Gold = {
        ["minecraft:gold_ore"] = true,
        ["minecraft:deepslate_gold_ore"] = true
    },

    Iron = {
        ["minecraft:iron_ore"] = true,
        ["minecraft:deepslate_iron_ore"] = true
    }
}


term.clear()
term.setCursorPos(1,1)

print("=== ORE FINDER ===")
print("")
print("1 - Diamond")
print("2 - Gold")
print("3 - Iron")
print("")

write("Select: ")

local choice = read()

local selectedOre = nil
local oreName = ""


if choice == "1" then
    selectedOre = ores.Diamond
    oreName = "Diamond"

elseif choice == "2" then
    selectedOre = ores.Gold
    oreName = "Gold"

elseif choice == "3" then
    selectedOre = ores.Iron
    oreName = "Iron"

else
    print("Invalid selection")
    return
end


local target = nil


local function distance(block)

    return math.sqrt(
        block.x * block.x +
        block.y * block.y +
        block.z * block.z
    )

end



local function showDirection(block)

    if block.x > 0 then
        print(math.abs(block.x).." blocks East")
    elseif block.x < 0 then
        print(math.abs(block.x).." blocks West")
    else
        print("Same East/West")
    end


    if block.y > 0 then
        print(block.y.." blocks Up")
    elseif block.y < 0 then
        print(math.abs(block.y).." blocks Down")
    else
        print("Same Height")
    end


    if block.z > 0 then
        print(block.z.." blocks South")
    elseif block.z < 0 then
        print(math.abs(block.z).." blocks North")
    else
        print("Same North/South")
    end

end



print("")
print("Searching for "..oreName.."...")


while true do

    local results = scanner.scan(16)


    if type(results) ~= "table" then
        print("Scanner failed")
        sleep(1)
        continue
    end



    -- Check locked target

    if target then

        local found = false


        for i = 1, #results do

            local block = results[i]


            if block
            and block.name
            and block.x
            and block.y
            and block.z then


                if block.name == target.name
                and block.x == target.x
                and block.y == target.y
                and block.z == target.z then

                    found = true
                    break

                end
            end
        end



        if not found then

            print("")
            print("TARGET MINED!")
            print("Finding new target...")

            target = nil

        end

    end



    -- Find closest ore

    if not target then


        local closest = nil
        local closestDistance = math.huge


        for i = 1, #results do

            local block = results[i]


            if block
            and block.name
            and block.x
            and block.y
            and block.z then


                if selectedOre[block.name] then


                    local d = distance(block)


                    if d < closestDistance then

                        closestDistance = d
                        closest = block

                    end

                end
            end
        end



        if closest then

            target = closest

            print("")
            print("LOCKED ON:")
            print(target.name)

        end

    end



    term.clear()
    term.setCursorPos(1,1)


    if target then

        print("=== LOCKED TARGET ===")
        print(target.name)
        print("")

        print(
            string.format(
                "Distance: %.1f blocks",
                distance(target)
            )
        )

        print("")
        showDirection(target)


    else

        print("Searching...")
        print("")
        print("No "..oreName.." found nearby.")

    end


    sleep(0.5)

end
