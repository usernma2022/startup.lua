-- tung 2.0

local scanner = peripheral.find("geoScanner")

if not scanner then
    print("No Geo Scanner found.")
    return
end


local ores = {
    Diamond = {
        ["minecraft:diamond_ore"] = true,
        ["minecraft:deepslate_diamond_ore"] = true
    },

    Gold = {
        ["minecraft:gold_ore"] = true,
        ["minecraft:deepslate_gold_ore"] = true
    },

    Iron = {
        ["minecraft:iron_ore"] = true,
        ["minecraft:deepslate_iron_ore"] = true
    }
}


print("=== ORE FINDER ===")
print("")
print("1 - Diamond")
print("2 - Gold")
print("3 - Iron")
print("")

write("Choose: ")
local choice = read()


local selectedOre
local oreName


if choice == "1" then
    selectedOre = ores.Diamond
    oreName = "Diamond"

elseif choice == "2" then
    selectedOre = ores.Gold
    oreName = "Gold"

elseif choice == "3" then
    selectedOre = ores.Iron
    oreName = "Iron"

else
    print("Invalid choice")
    return
end



local target = nil



local function getDistance(block)

    return math.sqrt(
        block.x^2 +
        block.y^2 +
        block.z^2
    )

end



local function printDirection(block)

    if block.x > 0 then
        print(math.abs(block.x).." blocks East")
    elseif block.x < 0 then
        print(math.abs(block.x).." blocks West")
    else
        print("Same East/West")
    end


    if block.y > 0 then
        print(block.y.." blocks Up")
    elseif block.y < 0 then
        print(math.abs(block.y).." blocks Down")
    else
        print("Same Height")
    end


    if block.z > 0 then
        print(block.z.." blocks South")
    elseif block.z < 0 then
        print(math.abs(block.z).." blocks North")
    else
        print("Same North/South")
    end

end



print("")
print("Tracking "..oreName)



while true do

    local results = scanner.scan(16)



    -- Check if current target still exists

    if target then

        local stillThere = false


        for _, block in ipairs(results) do

            if block.name == target.name
            and block.x == target.x
            and block.y == target.y
            and block.z == target.z then

                stillThere = true
                break

            end

        end


        if not stillThere then

            print("")
            print("Target mined!")
            print("Searching again...")

            target = nil

        end

    end



    -- Find closest ore

    if target == nil then

        local closest = nil
        local closestDistance = math.huge


        for _, block in ipairs(results) do

            if selectedOre[block.name] then

                local distance = getDistance(block)


                if distance < closestDistance then

                    closestDistance = distance
                    closest = block

                end

            end

        end



        if closest then

            target = closest

            print("")
            print("LOCKED ON")
            print(target.name)

        end

    end



    -- Display target

    term.clear()
    term.setCursorPos(1,1)


    if target then

        print("=== ORE LOCK ===")
        print(target.name)
        print("")

        print(
            string.format(
                "Distance: %.1f blocks",
                getDistance(target)
            )
        )

        print("")
        printDirection(target)

    else

        print("Searching for "..oreName.."...")

    end


    sleep(0.5)

end
