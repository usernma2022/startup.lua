-- tung tung

local scanner = peripheral.find("geoScanner")

if not scanner then
    print("No Geo Scanner found.")
    return
end


local ores = {
    Diamond = {
        ["minecraft:diamond_ore"] = true,
        ["minecraft:deepslate_diamond_ore"] = true
    },

    Gold = {
        ["minecraft:gold_ore"] = true,
        ["minecraft:deepslate_gold_ore"] = true
    },

    Iron = {
        ["minecraft:iron_ore"] = true,
        ["minecraft:deepslate_iron_ore"] = true
    }
}


print("=== ORE FINDER ===")
print("")
print("1. Diamond")
print("2. Gold")
print("3. Iron")
print("")

write("Choose ore: ")
local choice = read()


local selectedOre

if choice == "1" then
    selectedOre = ores.Diamond
    print("Tracking Diamonds")

elseif choice == "2" then
    selectedOre = ores.Gold
    print("Tracking Gold")

elseif choice == "3" then
    selectedOre = ores.Iron
    print("Tracking Iron")

else
    print("Invalid choice")
    return
end


local target = nil


local function getDistance(block)
    return math.sqrt(
        block.x^2 +
        block.y^2 +
        block.z^2
    )
end


local function printDirection(block)

    if block.x > 0 then
        print(math.abs(block.x) .. " blocks East")
    elseif block.x < 0 then
        print(math.abs(block.x) .. " blocks West")
    else
        print("Same East/West position")
    end


    if block.y > 0 then
        print(block.y .. " blocks Up")
    elseif block.y < 0 then
        print(math.abs(block.y) .. " blocks Down")
    else
        print("Same height")
    end


    if block.z > 0 then
        print(block.z .. " blocks South")
    elseif block.z < 0 then
        print(math.abs(block.z) .. " blocks North")
    else
        print("Same North/South position")
    end

end



while true do

    local results = scanner.scan(16)


    if type(results) ~= "table" then
        print("Scanner error")
        sleep(1)
        continue
    end



    -- Check current target

    if target then

        local exists = false

        for _, block in ipairs(results) do

            if block
            and block.name
            and block.x
            and block.y
            and block.z then

                if block.name == target.name
                and block.x == target.x
                and block.y == target.y
                and block.z == target.z then

                    exists = true
                    break

                end
            end

        end


        if not exists then

            print("")
            print("================")
            print("TARGET MINED!")
            print("Searching...")
            print("================")

            target = nil

        end

    end



    -- Find new target

    if not target then

        local closest = nil
        local closestDistance = math.huge


        for _, block in ipairs(results) do

            if block
            and block.name
            and block.x
            and block.y
            and block.z then


                if selectedOre[block.name] then

                    local distance = getDistance(block)


                    if distance < closestDistance then

                        closestDistance = distance
                        closest = block

                    end

                end
            end

        end



        if closest then

            target = closest

            print("")
            print("================")
            print("LOCKED ON")
            print(target.name)
            print("================")

        end

    end



    -- Display tracking

    if target
    and target.x
    and target.y
    and target.z then


        local distance = getDistance(target)


        print("")
        print("----------------")
        print("TARGET:")
        print(target.name)

        print(
            string.format(
                "Distance: %.1f blocks",
                distance
            )
        )

        print("Direction:")
        printDirection(target)

        print("----------------")


    else

        print("")
        print("No ore found.")

    end


    sleep(0.5)

end
