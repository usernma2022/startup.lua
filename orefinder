local scanner = peripheral.find("geoScanner")

if not scanner then
    print("No Geo Scanner found.")
    return
end


local oreOptions = {
    {
        name = "Diamond",
        ores = {
            "minecraft:diamond_ore",
            "minecraft:deepslate_diamond_ore"
        }
    },

    {
        name = "Gold",
        ores = {
            "minecraft:gold_ore",
            "minecraft:deepslate_gold_ore"
        }
    },

    {
        name = "Iron",
        ores = {
            "minecraft:iron_ore",
            "minecraft:deepslate_iron_ore"
        }
    }
}


print("=== ORE FINDER ===")
print("")
print("1. Diamond")
print("2. Gold")
print("3. Iron")
print("4. Custom")
print("")


write("Choose ore: ")
local choice = tonumber(read())


local selected


if choice and oreOptions[choice] then

    selected = oreOptions[choice]


elseif choice == 4 then

    print("")
    print("Enter block IDs separated by commas:")
    print("Example:")
    print("minecraft:emerald_ore,minecraft:deepslate_emerald_ore")
    print("")

    write("> ")

    local input = read()

    local blocks = {}

    for block in string.gmatch(input, "([^,]+)") do
        table.insert(blocks, block)
    end


    selected = {
        name = "Custom",
        ores = blocks
    }


else

    print("Invalid choice")
    return

end



while true do

    local results = scanner.scan(16)


    local closest = nil
    local closestDistance = math.huge


    for _, block in ipairs(results) do


        for _, targetBlock in ipairs(selected.ores) do


            if block.name == targetBlock then

                local distance = math.sqrt(
                    block.x^2 +
                    block.y^2 +
                    block.z^2
                )


                if distance < closestDistance then

                    closestDistance = distance
                    closest = block

                end

                break

            end

        end

    end



    term.clear()
    term.setCursorPos(1,1)


    print("Tracking: "..selected.name)
    print("")


    if closest then

        print("Found:")
        print(closest.name)
        print("")


        if closest.x > 0 then
            print(math.abs(closest.x).." blocks East")
        elseif closest.x < 0 then
            print(math.abs(closest.x).." blocks West")
        else
            print("Same East/West")
        end


        if closest.y > 0 then
            print(closest.y.." blocks Up")
        elseif closest.y < 0 then
            print(math.abs(closest.y).." blocks Down")
        else
            print("Same Height")
        end


        if closest.z > 0 then
            print(closest.z.." blocks South")
        elseif closest.z < 0 then
            print(math.abs(closest.z).." blocks North")
        else
            print("Same North/South")
        end


        print("")
        print(string.format(
            "Distance: %.1f blocks",
            closestDistance
        ))


    else

        print("No blocks found.")

    end


    sleep(2)

end
