local monitor = peripheral.find("monitor")
local detector = peripheral.find("player_detector") or peripheral.find("playerDetector")

monitor.clear()
monitor.setCursorPos(1,1)

local line = 1

for _, player in ipairs(detector.getOnlinePlayers()) do
    local info = detector.getPlayer(player)

    monitor.setCursorPos(1, line)
    monitor.write(player)
    line = line + 1

    local data = textutils.serialize(info)

    for str in string.gmatch(data, "[^\n]+") do
        monitor.setCursorPos(1, line)
        monitor.write(str)
        line = line + 1
    end

    line = line + 1
end
