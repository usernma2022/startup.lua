-- Used to see if specific blocks have methods in them that can be controlled in a CC Computer.

local function safeCall(obj, fn)
    if type(obj[fn]) ~= "function" then return end

    print("\n>> Testing: " .. fn)

    local ok, result = pcall(function()
        return obj[fn]()
    end)

    if ok then
        if type(result) == "table" then
            print(textutils.serialize(result))
        else
            print(tostring(result))
        end
    else
        print("FAILED: " .. tostring(result))
    end
end


for _, side in ipairs(peripheral.getNames()) do
    local p = peripheral.wrap(side)

    print("\n========================")
    print("SIDE:", side)
    print("TYPE:", peripheral.getType(side))
    print("========================")

    for k, v in pairs(p) do
        if type(v) == "function" then
            print("METHOD: " .. k)
        end
    end

    print("\n--- METHOD TESTS ---")

    -- common safe probes (won’t break most systems)
    local tests = {
        "getInfo",
        "list",
        "getItems",
        "getInventory",
        "getTanks",
        "getFluidInTank",
        "getTargetSpeed",
        "getEnergy",
        "getStoredItems"
    }

    for _, fn in ipairs(tests) do
        safeCall(p, fn)
    end
end
